{
  "extends": "@junat/tsconfig/next.json",
  "compilerOptions": {
    "moduleResolution": "bundler",
    "lib": ["esnext", "dom", "webworker"],
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"]
    },
    "types": ["@serwist/next/typings", "@types/umami-browser"]
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}
